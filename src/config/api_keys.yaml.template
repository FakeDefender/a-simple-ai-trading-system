# 可选配置。v0.1 默认不依赖 LLM。
# 如需启用，请复制为 api_keys.yaml 并填写对应 provider。

deepseek:
  api_key: your-deepseek-api-key
  base_url: https://api.deepseek.com

openai:
  api_key: your-openai-api-key
  base_url: https://api.openai.com/v1

# 可选：真实券商 REST 接入。key 名需与 broker.provider 一致。
generic_rest:
  api_key: your-broker-api-token
  base_url: https://your-broker-api
